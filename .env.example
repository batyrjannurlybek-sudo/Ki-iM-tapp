# Supabase — get these from your project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only. Used by admin/seed scripts. NEVER expose to the client.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Password for the /admin moderation panel. CHANGE THIS before deploying.
ADMIN_PASSWORD=change-me

# Public site URL — used for SEO (sitemap, canonical, Open Graph).
# On Vercel set this to your domain, e.g. https://ki-im-tapp.vercel.app
NEXT_PUBLIC_SITE_URL=http://localhost:3000
